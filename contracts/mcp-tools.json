[
  {
    "name": "search_hot_notes",
    "description": "[研究/选题] 搜索公开网页索引或授权数据中的近期小红书热门笔记，并返回 hot_insights（爆款标签/热度带/原因）。若未配置搜索 API，且未传入 web_results，会返回 needs_web_search，宿主 agent 应先 websearch 再带着 web_results 重试。公开结果不代表站内全量热榜。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string"
        },
        "time_range": {
          "type": "string",
          "default": "7d"
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "providers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "web_results": {
          "type": "array",
          "description": "宿主 websearch 结果。每项至少 url+title；可含 snippet/published_at/互动数字段。",
          "items": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "snippet": {
                "type": "string"
              },
              "published_at": {
                "type": "string"
              },
              "source_rank": {
                "type": "integer"
              },
              "likes": {
                "type": "integer"
              },
              "saves": {
                "type": "integer"
              },
              "comments": {
                "type": "integer"
              },
              "shares": {
                "type": "integer"
              },
              "views": {
                "type": "integer"
              },
              "author_name": {
                "type": "string"
              }
            },
            "required": [
              "url",
              "title"
            ],
            "additionalProperties": true
          }
        }
      },
      "required": [
        "query"
      ],
      "additionalProperties": false
    },
    "_meta": {
      "category": "research",
      "category_label": "研究/选题"
    },
    "annotations": {
      "category": "research"
    }
  },
