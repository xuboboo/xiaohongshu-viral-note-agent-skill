APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8080
APP_SECRET_KEY=replace-with-at-least-32-random-bytes
AUTH_REQUIRED=true
AUTH_ISSUER=xhs-skill
AUTH_AUDIENCE=xhs-skill-api
AUTH_TOKEN_TTL_SECONDS=3600
TRUSTED_PROXY_CIDRS=
MAX_REQUEST_BODY_BYTES=2097152
ASSET_UPLOAD_MAX_BYTES=52428800
AUTHORIZED_IMPORT_MAX_BYTES=10485760
DATABASE_URL=sqlite+aiosqlite:///./data/xhs_skill.db
REDIS_URL=
OBJECT_STORAGE_DIR=./data/objects

# Model providers
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_DEFAULT_MODEL=
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_DEFAULT_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=
QWEN_DEFAULT_MODEL=
ARK_API_KEY=
ARK_BASE_URL=
ARK_DEFAULT_MODEL=
ZHIPU_API_KEY=
ZHIPU_BASE_URL=
GLM_DEFAULT_MODEL=
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=
KIMI_DEFAULT_MODEL=
MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_DEFAULT_MODEL=
HUNYUAN_API_KEY=
HUNYUAN_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
HUNYUAN_DEFAULT_MODEL=
QIANFAN_API_KEY=
QIANFAN_BASE_URL=
QIANFAN_DEFAULT_MODEL=
MODEL_PROVIDERS_FILE=./assets/providers.yaml
AWS_REGION=

# Search providers
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_BASE_URL=https://api.search.brave.com/res/v1
SEARXNG_BASE_URL=
BING_SEARCH_API_KEY=
BING_SEARCH_BASE_URL=https://api.bing.microsoft.com/v7.0/search
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
GOOGLE_SEARCH_BASE_URL=https://www.googleapis.com/customsearch/v1
# When no live search key and no web_results: delegate | fixture | error
# delegate (default): return needs_web_search so host agent can websearch and re-call
SEARCH_AUTO_FALLBACK=delegate

# Browser / publishing
XHS_CREATOR_STUDIO_URL=https://creator.xiaohongshu.com
XHS_BROWSER_HEADLESS=false
XHS_PUBLISH_DEFAULT_MODE=REQUIRE_CONFIRMATION
XHS_FULLY_AUTOMATED_ENABLED=false
XHS_DAILY_PUBLISH_LIMIT=3
XHS_MIN_PUBLISH_INTERVAL_MINUTES=120
XHS_SESSION_DIR=./playwright/.auth
XHS_SCREENSHOT_DIR=./output/screenshots
XHS_SELECTOR_CONFIG=./assets/creator_studio_selectors.yaml
XHS_ACCOUNTS_CONFIG=./assets/accounts.yaml
XHS_PUBLISH_ADAPTER=creator_studio
XHS_MANUAL_EXPORT_DIR=./output/manual-publish
XHS_SCHEDULE_POLL_SECONDS=2
XHS_SCHEDULING_ENABLED=true
XHS_DISTRIBUTED_SCHEDULING_ENABLED=false
XHS_REQUIRE_IDENTITY_VERIFIED=true
MCP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# High-concurrency runtime
MAX_INFLIGHT_REQUESTS=512
SSE_MAX_CONNECTIONS=10000
MAX_QUEUED_WAITERS=1024
CONCURRENCY_WAIT_TIMEOUT_SECONDS=2
PER_TENANT_CONCURRENCY=32
PER_TENANT_MAX_WAITERS=128
PER_TENANT_SSE_CONNECTIONS=1000
PER_PROVIDER_CONCURRENCY=64
PER_PROVIDER_MAX_WAITERS=256
RESEARCH_CONCURRENCY=128
GENERATION_CONCURRENCY=128
BROWSER_CONCURRENCY=8
PUBLISH_CONCURRENCY=4
RATE_LIMIT_REQUESTS_PER_SECOND=50
RATE_LIMIT_BURST=100
PROVIDER_RATE_LIMIT_REQUESTS_PER_SECOND=20
PROVIDER_RATE_LIMIT_BURST=40
DISTRIBUTED_RATE_LIMIT_ENABLED=true
DISTRIBUTED_LOCKS_ENABLED=true
DISTRIBUTED_LOCK_TTL_SECONDS=120

HTTP_MAX_CONNECTIONS=1000
HTTP_MAX_KEEPALIVE_CONNECTIONS=256
HTTP_KEEPALIVE_EXPIRY_SECONDS=30
HTTP_CONNECT_TIMEOUT_SECONDS=5
HTTP_POOL_TIMEOUT_SECONDS=2
HTTP2_ENABLED=true

JOB_WORKER_CONCURRENCY=64
JOB_QUEUE_CAPACITY=10000
JOB_MAX_RETRIES=3
JOB_WORKER_FETCH_COUNT=100
JOB_WORKER_BLOCK_MS=5000
JOB_VISIBILITY_TIMEOUT_MS=120000
DISTRIBUTED_JOBS_ENABLED=false
REDIS_EVENTS_ENABLED=true
REDIS_MAX_CONNECTIONS=500
REDIS_EVENT_TTL_SECONDS=86400
REDIS_JOB_TTL_SECONDS=604800
UVICORN_WORKERS=1
GRACEFUL_SHUTDOWN_SECONDS=30
DISTRIBUTED_CACHE_ENABLED=true
CACHE_MAX_ENTRIES=10000
SEARCH_CACHE_TTL_SECONDS=300

# Enterprise v5 identity, governance and supply-chain
ENTERPRISE_ENABLED=true
ENTERPRISE_STRICT_MODE=false
AUTH_MODE=hybrid
OIDC_ISSUER=
OIDC_AUDIENCE=xhs-skill-api
OIDC_DISCOVERY_URL=
OIDC_ALLOWED_ALGORITHMS=RS256,ES256,EdDSA
OIDC_TENANT_CLAIM=tenant_id
OIDC_SCOPE_CLAIM=scope
OIDC_ROLES_CLAIM=roles
OIDC_REGION_CLAIM=region
OIDC_CACHE_TTL_SECONDS=3600
OAUTH_RESOURCE_IDENTIFIER=http://127.0.0.1:8080
SCIM_ENABLED=true
SCIM_REQUIRE_MANAGED_USER=false
SCIM_REJECT_INACTIVE_USERS=true
ENTERPRISE_DEFAULT_REGION=global
ENTERPRISE_DEFAULT_DAILY_BUDGET_USD=100
ENTERPRISE_DEFAULT_MONTHLY_BUDGET_USD=2000
ENTERPRISE_PUBLISH_APPROVAL_QUORUM=2
ENTERPRISE_SEPARATION_OF_DUTIES=true
ENTERPRISE_REQUIRE_PHISHING_RESISTANT_MFA=true
ENTERPRISE_POLICY_ENFORCEMENT=true
ENTERPRISE_ENFORCE_PUBLISH_QUORUM=false
ENTERPRISE_COST_ENFORCEMENT=false
ENTERPRISE_DATA_DIR=./data/enterprise
AUDIT_ENABLED=true
AUDIT_DIR=./data/audit
AUDIT_HMAC_KEY=
AUDIT_S3_BUCKET=
AUDIT_S3_PREFIX=xhs-skill-audit
AUDIT_S3_OBJECT_LOCK_DAYS=365
SECRET_BACKEND=local
VAULT_ADDR=
VAULT_TOKEN=
VAULT_TRANSIT_MOUNT=transit
VAULT_TRANSIT_KEY=xhs-skill
AWS_KMS_KEY_ID=
PLUGIN_TRUST_STORE=./data/enterprise/plugin-trust.json
PLUGIN_ALLOW_UNSIGNED_IN_DEVELOPMENT=false
DLP_ENABLED=true
DLP_BLOCK_SECRETS=true
RETENTION_WORKER_ENABLED=false
ENTERPRISE_REQUIRE_EXTERNAL_SECRET_BACKEND=true
# v5.1 distributed consistency
POSTGRES_STATE_ENABLED=false
ENTERPRISE_WORKER_TENANT_IDS=[]
OUTBOX_WORKER_ENABLED=false
OUTBOX_WORKER_BATCH_SIZE=100
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_LEASE_SECONDS=120
DISTRIBUTED_CANCEL_POLL_SECONDS=0.25
SCHEDULER_LEASE_SECONDS=180
SCHEDULER_CLAIM_BATCH_SIZE=20

# v5.1 content intelligence
EMBEDDING_PROVIDER=hashing
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=512
SEMANTIC_SIMILARITY_BLOCK=0.92
MINHASH_SIMILARITY_BLOCK=0.82
SIMHASH_HAMMING_BLOCK=6
RARE_PHRASE_MATCH_BLOCK=2
IMAGE_PHASH_DISTANCE_BLOCK=6
OCR_ENABLED=false
LEARNING_RANKER_MODEL_PATH=./data/models/title_lambdamart.txt

# v5.1 operations loop
OPERATIONS_DB_PATH=./data/operations.sqlite3
DEFAULT_CONTENT_CALENDAR_DAYS=30
BANDIT_EXPLORATION_ALPHA=1.0
ASSET_LIBRARY_DIR=./data/asset-library
POST_PUBLISH_SYNC_ENABLED=true
POST_PUBLISH_SYNC_DELAYS_MINUTES=[60,1440,4320]
POST_PUBLISH_SYNC_MAX_ATTEMPTS=8
POST_PUBLISH_SYNC_LEASE_SECONDS=180

